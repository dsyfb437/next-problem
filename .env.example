# Flask secret key - generate a random string for production
# Run: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=YOUR_SECRET_KEY_HERE

# Deploy key for /git_pull route - set a random strong password
# Run: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Usage: curl https://your-app.pythonanywhere.com/git_pull?key=<DEPLOY_KEY>
DEPLOY_KEY=YOUR_DEPLOY_KEY_HERE

# Database URL
# Leave empty for JSON file storage (default)
DATABASE_URL=

# Flask environment
FLASK_ENV=production
